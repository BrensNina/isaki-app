{
  "name": "isaki-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "clean:opennext": "node scripts/clean-opennext.mjs",
    "predeploy": "npm run clean:opennext",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preupload": "npm run clean:opennext",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "prepreview": "npm run clean:opennext",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.9",
    "firebase": "^12.15.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.21.0",
    "next": "16.2.6",
    "react": "^19.1.7",
    "react-dom": "^19.1.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "wrangler": "^4.104.0"
  }
}
